# RepoLens AI local configuration template.
# Copy this file to `.env` locally or export these variables in your shell.
# Never commit real secrets. This file must contain placeholders only.
#
# Free / offline defaults:
# - `EMBEDDING_PROVIDER=hashing`
# - `ANSWER_PROVIDER=extractive`
# Those defaults avoid paid LLM usage.

GEMINI_API_KEY=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
EMBEDDING_PROVIDER=hashing
VECTOR_STORE_PROVIDER=memory
ANSWER_PROVIDER=extractive
DATABASE_URL=sqlite:///./.data/repolens.db
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CHUNKING_STRATEGY=symbol
CHUNK_SIZE_LINES=80
CHUNK_OVERLAP_LINES=20
MAX_FILE_SIZE_BYTES=200000
MAX_LOCKFILE_SIZE_BYTES=75000
TOP_K=6
ENABLE_RERANK=false
